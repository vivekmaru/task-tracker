# Copy to .env and fill in real values. .env is git-ignored; never commit secrets.

# Public domain Caddy will obtain a certificate for. Use "localhost" with the
# internal-TLS Caddyfile variant for LAN deployments.
FORGE_DOMAIN=forge.example.com

# Postgres credentials. POSTGRES_PASSWORD is required.
POSTGRES_USER=forge
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=forge

# Database URL the Forge processes use. Host must be the compose service name
# "postgres". Keep the password in sync with POSTGRES_PASSWORD above.
FORGE_DATABASE_URL=postgres://forge:replace-with-a-strong-password@postgres:5432/forge?sslmode=disable

# Operator admin token for the human web UI and /api/v1 bearer auth.
# Generate a 32-byte token, e.g.: openssl rand -base64 32
FORGE_ADMIN_TOKEN=replace-with-a-32-byte-token

# Optional: pin a specific published image instead of building locally.
# FORGE_IMAGE=ghcr.io/your-org/forge:v0.1.0
